# VLESS VPN SaaS - Environment Variables Example
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=false
APP_NAME="VLESS VPN SaaS"
APP_VERSION="3.0.0-saas"

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Supabase (https://supabase.com)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# =============================================================================
# Stripe (https://stripe.com)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_BASIC=price_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_xxx

# =============================================================================
# Coinbase Commerce (https://commerce.coinbase.com)
# =============================================================================
COINBASE_API_KEY=xxx
COINBASE_WEBHOOK_SECRET=xxx

# =============================================================================
# VPN Configuration
# =============================================================================
VLESS_SECRET=your-vless-secret-key

# =============================================================================
# Database (if not using Supabase)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/vpn_saas

# =============================================================================
# Redis (for caching and rate limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Email (for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# =============================================================================
# Telegram Bot (for alerts)
# =============================================================================
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx
